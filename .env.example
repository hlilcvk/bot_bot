# ──────────────────────────────────────────────────
#  PROPTREX Radar – Environment Variables
#  Copy this file as .env and fill in your values
# ──────────────────────────────────────────────────

# Server
HOST=0.0.0.0
PORT=8000

# Telegram Integration
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# Public URL (used for Telegram deep-links etc.)
PUBLIC_BASE_URL=https://your-domain.com

# Billing Provider: "stripe" or "paddle" or "" (disabled)
BILLING_PROVIDER=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_IDS_JSON=
STRIPE_CUSTOMER_PORTAL_URL=

# Paddle
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_IDS_JSON=

# Checkout URLs
CHECKOUT_SUCCESS_URL=
CHECKOUT_CANCEL_URL=
BILLING_PORTAL_URL=

# Admin
ADMIN_SECURITY_TOKEN=
